#!/bin/bash
# toggle-shell — Switch between shell modes: doublepanel, crystaldock, minimal, dms, noctalia
#
# Env vars (read at switch time, written to env.config):
#   OCWS_BAR_THICKNESS  — single-bar thickness (default: 34px)
#   OCWS_TOP_SIZE       — top bar height in doublepanel mode (default: 32)
#   OCWS_BOTTOM_SIZE    — bottom bar height in doublepanel mode (default: 40)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Centralized error handling + desktop notifications (ocws-notify / mako / dunst)
source "$SCRIPT_DIR/lib/ocws-err.sh"
ocws_enable_strict

OCWS_DIR="$HOME/.config/ocws"
CFG="$OCWS_DIR/mode"
mkdir -p "$OCWS_DIR"

# Available modes
declare -A MODES=(
    ["doublepanel"]="labwc + double-panel sfwbar (top status bar + bottom dock/taskbar)"
    ["crystaldock"]="labwc + sfwbar statusbar + crystal-dock"
    ["minimal"]="labwc + minimal sfwbar (clock, volume, battery, tray)"
    ["dms"]="labwc + dankmaterialshell"
    ["noctalia"]="labwc + noctalia shell"
)

if [ -n "${1:-}" ]; then
    MODE="$1"
    MODE="${MODE#labwc-}"

    if [ -z "${MODES[$MODE]+x}" ]; then
        echo "Usage: $0 <mode>"
        echo ""
        echo "Modes:"
        for mode in "${!MODES[@]}"; do
            echo "  $mode  ${MODES[$mode]}"
        done
        exit 1
    fi

    NEW="$MODE"
else
    echo "Usage: $0 <mode>"
    echo ""
    echo "Modes:"
    for mode in "${!MODES[@]}"; do
        echo "  $mode  ${MODES[$mode]}"
    done
    exit 1
fi

CURRENT="$(cat "$CFG" 2>/dev/null || echo doublepanel)"

echo "Current shell mode: $CURRENT"
echo "Switching to: $NEW"

# Kill existing shells
for p in crystal-dock sfwbar noctalia dms; do
    if pgrep -x "$p" >/dev/null; then
        echo "Stopping $p..."
        pkill -x "$p"
    fi
done

# Clean crystal-dock IPC artifacts
rm -f /tmp/qipc_sharedmemory_crystaldock* /tmp/qipc_systemsem_crystaldock* 2>/dev/null

sleep 0.3

# Validate configs based on mode
case "$NEW" in
    doublepanel|crystaldock|minimal)
        # Check for modular configs
        if [ -d "$PROJECT_DIR/dotfiles/ocws/modes" ]; then
            echo "Using modular config system"
            # Copy modes directory to user config
            mkdir -p "$OCWS_DIR/modes"
            cp -r "$PROJECT_DIR/dotfiles/ocws/modes/"* "$OCWS_DIR/modes/" 2>/dev/null || true
        elif [ ! -f "$OCWS_DIR/ocws.config" ] && [ ! -f "$OCWS_DIR/sfwbar-full.config" ]; then
            ocws_die "toggle-shell: No OCWS config found in $OCWS_DIR (run install.sh first)"
        fi
        ;;
esac

# Generate env.config from OCWS_* env vars (read by sfwbar configs)
if [ "$NEW" = "doublepanel" ] || [ "$NEW" = "crystaldock" ] || [ "$NEW" = "minimal" ]; then
    cat > "$OCWS_DIR/env.config" <<-EOF
# env.config — generated by toggle-shell $(date +%Y-%m-%dT%H:%M:%S)
Set OCWSBarThickness = "${OCWS_BAR_THICKNESS:-34px}"
Set OCWSTopSize = "${OCWS_TOP_SIZE:-32}"
Set OCWSBottomSize = "${OCWS_BOTTOM_SIZE:-40}"
EOF
fi

# Start new configuration
case "$NEW" in
    dms)
        echo "Starting dms..."
        if command -v dms >/dev/null 2>&1; then
            nohup dms run >/dev/null 2>&1 &
            echo "Started dms"
        else
            ocws_die "toggle-shell: dms is not installed"
        fi
        ;;
    noctalia)
        echo "Starting noctalia..."
        if command -v noctalia >/dev/null 2>&1; then
            nohup noctalia >/dev/null 2>&1 &
            echo "Started noctalia"
        else
            ocws_die "toggle-shell: noctalia is not installed"
        fi
        ;;
    doublepanel)
        echo "Starting OCWS (double-panel sfwbar)..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        sleep 0.2
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/doublepanel.mode" ]; then
            nohup sfwbar -c "$OCWS_DIR/modes/doublepanel.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: doublepanel.mode)"
        else
            nohup sfwbar -f "$OCWS_DIR/ocws.config" >/dev/null 2>&1 &
            echo "Started sfwbar (ocws.config)"
        fi
        ;;
    crystaldock)
        echo "Starting sfwbar statusbar + crystal-dock..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        sleep 0.2
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/crystaldock.mode" ]; then
            nohup sfwbar -c "$OCWS_DIR/modes/crystaldock.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: crystaldock.mode)"
        else
            nohup sfwbar -f "$OCWS_DIR/sfwbar-full.config" >/dev/null 2>&1 &
            echo "Started sfwbar (sfwbar-full.config)"
        fi
        if command -v crystal-dock >/dev/null 2>&1; then
            nohup crystal-dock >/dev/null 2>&1 &
            echo "Started crystal-dock"
        else
            echo "warning: crystal-dock not found — only sfwbar bar is running"
        fi
        ;;
    minimal)
        echo "Starting OCWS (minimal sfwbar)..."
        command -v ocws-plugin-loader.sh >/dev/null 2>&1 && ocws-plugin-loader.sh
        pkill -x sfwbar 2>/dev/null || true
        sleep 0.2
        # Use modular config if available
        if [ -f "$OCWS_DIR/modes/minimal.mode" ]; then
            nohup sfwbar -c "$OCWS_DIR/modes/minimal.mode" >/dev/null 2>&1 &
            echo "Started sfwbar (modular: minimal.mode)"
        else
            ocws_die "toggle-shell: minimal mode config not found (run install.sh)"
        fi
        ;;
esac

# Update configuration
echo "$NEW" > "$CFG"

echo ""
echo "Shell mode switched to: $NEW"
echo "Mode description: ${MODES[$NEW]}"
