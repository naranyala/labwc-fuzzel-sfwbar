#!/bin/bash
# toggle-shell — Switch between shell modes: noctalia, sfwbar-plus, sfwbar, crystal

set -euo pipefail

CFG="$HOME/.config/ocws/mode"
mkdir -p "$(dirname "$CFG")"

if [ -n "${1:-}" ]; then
    MODE="$1"

    if [ "$MODE" != "dms" ] && [ "$MODE" != "noctalia" ] && [ "$MODE" != "sfwbar-plus" ] && [ "$MODE" != "sfwbar" ] && [ "$MODE" != "crystal" ]; then
        echo "Usage: $0 <mode>"
        echo ""
        echo "Modes:"
        echo "  dms          labwc + dankmaterialshell (default)"
        echo "  noctalia     labwc + noctalia shell"
        echo "  sfwbar-plus  labwc + enhanced OCWS dual panel"
        echo "  sfwbar       labwc + sfwbar only (minimal OCWS)"
        echo "  crystal      labwc + crystal-dock only"
        exit 1
    fi

    NEW="$MODE"
else
    echo "Usage: $0 <mode>"
    exit 1
fi

CURRENT="$(cat "$CFG" 2>/dev/null || echo dms)"

echo "Current shell mode: $CURRENT"
echo "Switching to: $NEW"

# Kill existing shells
if pgrep -x crystal-dock >/dev/null; then
    echo "Stopping crystal-dock..."
    pkill -x crystal-dock
    rm -f /tmp/qipc_sharedmemory_crystaldock* /tmp/qipc_systemsem_crystaldock* 2>/dev/null
fi

if pgrep -x sfwbar >/dev/null; then
    echo "Stopping sfwbar..."
    pkill -x sfwbar
fi

if pgrep -x noctalia >/dev/null; then
    echo "Stopping noctalia..."
    pkill -x noctalia
fi

if pgrep -x dms >/dev/null; then
    echo "Stopping dms..."
    pkill -x dms
fi

sleep 0.3

# Start new configuration
case "$NEW" in
    dms)
        echo "Starting dms..."
        if command -v dms >/dev/null 2>&1; then
            nohup dms run >/dev/null 2>&1 &
            echo "Started dms"
        else
            echo "error: dms not installed"
            exit 1
        fi
        ;;
    noctalia)
        echo "Starting noctalia..."
        if command -v noctalia >/dev/null 2>&1; then
            nohup noctalia >/dev/null 2>&1 &
            echo "Started noctalia"
        else
            echo "error: noctalia not installed"
            exit 1
        fi
        ;;
    sfwbar-plus)
        echo "Starting OCWS (sfwbar-plus mode)..."
        if command -v ocws-plugin-loader.sh >/dev/null 2>&1; then
            ocws-plugin-loader.sh
        fi
        pkill -x sfwbar 2>/dev/null
        sleep 0.2
        nohup sfwbar -f "$HOME/.config/ocws/ocws.config" >/dev/null 2>&1 &
        ;;
    sfwbar)
        echo "Starting sfwbar only (minimal)..."
        if command -v ocws-plugin-loader.sh >/dev/null 2>&1; then
            ocws-plugin-loader.sh
        fi
        pkill -x sfwbar 2>/dev/null
        sleep 0.2
        nohup sfwbar -f "$HOME/.config/ocws/ocws.config" >/dev/null 2>&1 &
        ;;
    crystal)
        echo "Starting crystal-dock only..."
        nohup crystal-dock >/dev/null 2>&1 &
        ;;
esac

# Update configuration
echo "$NEW" > "$CFG"

echo "✅ Shell mode switched to: $NEW"
