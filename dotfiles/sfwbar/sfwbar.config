#Api2

# Dark theme
Theme = "Adwaita-dark"

# Icon paths
Set ImagePath = "icons/misc:icons/weather"

# Bar thickness
Set ThicknessHint = "32px"

# Disable task switcher
TriggerAction "SIGRTMIN+1", SwitcherEvent("forward");
TriggerAction "SIGRTMIN+2", SwitcherEvent("back");

switcher {
  disable = true
}

# Window placer
placer {
  xorigin = 5
  yorigin = 5
  xstep = 5
  ystep = 5
  children = true
}

Function SfwbarInit() {
}

# Main bar - TOP, no taskbar
bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"

  # Workspaces - 9
  pager {
    style = "pager"
    rows = 1
    pins = "1","2","3","4","5","6","7","8","9"
    preview = true
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  # Taskbar - DISABLED
  taskbar {
    disable = true
  }

  # Spacer
  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # Text widgets
  widget "cpu-text.widget"
  widget "memory-text.widget"
  widget "network-text.widget"
  widget "volume-text.widget"
  widget "battery-text.widget"

  # Clock (after battery, before session)
  widget "clock.widget" {
    disable = false
    time_format = "%H:%M"
    tooltip_format = "%A %d %B %Y\n%H:%M:%S"
    week_starts_on_sunday = false
    reset_on_popup = false
  }

  # Session menu
  widget "session.widget" {
    session_actions = [
      ["system-lock-screen", "Lock", "loginctl lock-session"],
      ["system-log-out", "Logout", "loginctl terminate-user $USER"],
      ["system-reboot", "Reboot", "systemctl reboot"],
      ["system-shutdown", "Shutdown", "systemctl poweroff"]
    ]
  }
}
