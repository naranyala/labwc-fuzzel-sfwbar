#Api2

include("battery.source")

export label "battery-text" {
  interval = 10000
  style = battery-text
  value = "Bat " + Str(Level, 0) + "%"
  tooltip = "Battery: " + Str(Level, 0) + "%\nStatus: " + If(Discharging, "Discharging", "Charging")
  action = ExecTerm("upower -i /org/freedesktop/UPower/devices/battery_BAT0")
}

#CSS
label#battery-text {
  padding-left: 4px;
  padding-right: 4px;
  color: @theme_fg_color;
}
